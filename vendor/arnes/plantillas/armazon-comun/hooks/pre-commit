#!/usr/bin/env bash
# pre-commit hook de Arnes
#
# Se ejecuta automaticamente antes de cada `git commit`.
# Aborta el commit si alguna verificacion falla.
#
# Para instalar este hook en un proyecto:
#   ln -s ../../plantillas/armazon-comun/hooks/pre-commit .git/hooks/pre-commit
# O via husky / lefthook / simple-git-hooks (en package.json).

set -e

# Color helpers (en terminales que lo soporten)
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  NC='\033[0m'
else
  RED=''
  GREEN=''
  YELLOW=''
  NC=''
fi

echo ""
echo "Arnes pre-commit hook"
echo "====================="

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

FAIL=0

# ─── 1. Scan secrets ──────────────────────────────────────────────────
echo ""
echo -e "${YELLOW}1/4 Escaneando secrets...${NC}"

# El script de Arnes vive en la skill global o en el armazon copiado.
# Buscamos en orden de preferencia.
SCAN_SCRIPT=""
if [[ -f "$PROJECT_ROOT/hooks/scan-secrets.mjs" ]]; then
  SCAN_SCRIPT="$PROJECT_ROOT/hooks/scan-secrets.mjs"
elif [[ -f "$HOME/.claude/skills/arnes/plantillas/armazon-comun/hooks/scan-secrets.mjs" ]]; then
  SCAN_SCRIPT="$HOME/.claude/skills/arnes/plantillas/armazon-comun/hooks/scan-secrets.mjs"
fi

if [[ -n "$SCAN_SCRIPT" ]]; then
  if node "$SCAN_SCRIPT"; then
    echo -e "${GREEN}OK${NC}"
  else
    echo -e "${RED}FALLO: secrets detectados${NC}"
    FAIL=1
  fi
else
  echo -e "${YELLOW}AVISO: scan-secrets.mjs no encontrado. Saltando.${NC}"
fi

# ─── 2. Lint ─────────────────────────────────────────────────────────
echo ""
echo -e "${YELLOW}2/4 Linting...${NC}"
if [[ -f "$PROJECT_ROOT/package.json" ]] && grep -q '"lint"' "$PROJECT_ROOT/package.json"; then
  if pnpm lint 2>&1 | tail -50; then
    echo -e "${GREEN}OK${NC}"
  else
    echo -e "${RED}FALLO: lint con errores${NC}"
    FAIL=1
  fi
else
  echo -e "${YELLOW}AVISO: script 'lint' no encontrado en package.json. Saltando.${NC}"
fi

# ─── 3. Type-check ────────────────────────────────────────────────────
echo ""
echo -e "${YELLOW}3/4 Type-check...${NC}"
if [[ -f "$PROJECT_ROOT/package.json" ]] && grep -q '"typecheck"' "$PROJECT_ROOT/package.json"; then
  if pnpm typecheck 2>&1 | tail -50; then
    echo -e "${GREEN}OK${NC}"
  else
    echo -e "${RED}FALLO: errores de tipos${NC}"
    FAIL=1
  fi
else
  echo -e "${YELLOW}AVISO: script 'typecheck' no encontrado en package.json. Saltando.${NC}"
fi

# ─── 4. Tests (opcional, controlado por ARNES_PRECOMMIT_TESTS) ─────
# Por defecto NO corremos tests en pre-commit (pueden ser lentos).
# Se activa con: export ARNES_PRECOMMIT_TESTS=1
echo ""
if [[ "${ARNES_PRECOMMIT_TESTS:-0}" == "1" ]]; then
  echo -e "${YELLOW}4/4 Tests (ARNES_PRECOMMIT_TESTS=1)...${NC}"
  if [[ -f "$PROJECT_ROOT/package.json" ]] && grep -q '"test"' "$PROJECT_ROOT/package.json"; then
    if pnpm test --run 2>&1 | tail -50; then
      echo -e "${GREEN}OK${NC}"
    else
      echo -e "${RED}FALLO: tests rotos${NC}"
      FAIL=1
    fi
  fi
else
  echo -e "${YELLOW}4/4 Tests: saltando (ARNES_PRECOMMIT_TESTS no esta a 1)${NC}"
  echo "    Para activar: export ARNES_PRECOMMIT_TESTS=1"
fi

# ─── Resumen ────────────────────────────────────────────────────────
echo ""
if [[ $FAIL -eq 0 ]]; then
  echo -e "${GREEN}====================="
  echo -e "Arnes pre-commit: OK"
  echo -e "=====================${NC}"
  exit 0
else
  echo -e "${RED}========================="
  echo -e "Arnes pre-commit: FALLO"
  echo -e "Commit abortado."
  echo -e "=========================${NC}"
  echo ""
  echo "Si REALMENTE necesitas bypassear (no recomendado):"
  echo "  git commit --no-verify"
  echo ""
  exit 1
fi

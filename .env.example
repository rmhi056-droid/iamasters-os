# iAmasters OS — Environment Variables Template
# Copia este archivo a .env y rellena los valores que uses.
# .env NUNCA se commitea (está en .gitignore).

# ============================================================
# OPCIONAL — solo si vas a usar la skill que lo necesite
# ============================================================

# Firecrawl: para scrapear tu web/LinkedIn/YouTube y extraer voice samples + brand assets
# Sin esto, la skill marketing-brand-voice usará el fetch nativo (limitado)
# Cómo: regístrate en https://www.firecrawl.dev (500 créditos free) y copia tu API key
FIRECRAWL_API_KEY=

# YouTube API (opcional): para tool-youtube-transcript con metadatos extra
# Sin esto, se usa whisper local o transcript público
YOUTUBE_API_KEY=

# OpenAI (opcional): si usas Whisper API para transcripciones largas en lugar de mlx-whisper local
OPENAI_API_KEY=

# Groq (opcional): para tool-transcribe-social con Whisper rápido y barato
# Sin esto, la skill avisará claramente y no intentará transcribir en silencio
GROQ_API_KEY=

# ============================================================
# NO necesarias para Claude Code
# ============================================================
# Anthropic NO se pone aquí: Claude Code usa tu plan Pro/Max desde el login.
# La API solo si usas alguna skill que llame Anthropic SDK directo (raro en este repo).
# ANTHROPIC_API_KEY=

# ============================================================
# Para multi-cliente con APIs específicas (opcional)
# ============================================================
# Si un cliente usa GoHighLevel/HubSpot/Notion y tienes una skill que lo conecte
GHL_API_KEY=
HUBSPOT_API_KEY=
NOTION_API_KEY=

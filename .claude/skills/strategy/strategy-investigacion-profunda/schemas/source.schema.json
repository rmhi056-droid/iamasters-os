{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Source",
  "type": "object",
  "required": ["source_id", "raw_url"],
  "properties": {
    "source_id": {
      "type": "string",
      "description": "Hash sha256 truncado a 12 chars de la URL normalizada. Estable a través de renumeraciones."
    },
    "raw_url": {
      "type": "string",
      "format": "uri"
    },
    "title": {"type": "string"},
    "author": {"type": "string"},
    "publication": {"type": "string"},
    "year": {"type": "string"},
    "source_type": {
      "type": "string",
      "enum": ["academic", "peer_reviewed", "preprint", "news", "blog", "opinion", "documentation", "industry_report", "government", "web"]
    },
    "retrieved_at": {"type": "string", "format": "date-time"},
    "credibility_score": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100
    },
    "display_number": {
      "type": ["integer", "null"],
      "description": "[N] asignado en tiempo de render. Nunca almacenado como verdad de origen."
    }
  }
}
